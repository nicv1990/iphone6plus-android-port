+			     "known sequence: %016llx -> %016llx -> %016llx -> %016llx\n",
+			     AKF_KNOWN_BOOT_0, AKF_KNOWN_BOOT_1,
+			     AKF_KNOWN_BOOT_2, AKF_KNOWN_BOOT_3);
