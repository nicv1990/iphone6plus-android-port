diff --git a/drivers/soc/apple/t7000-ans-probe.c b/drivers/soc/apple/t7000-ans-probe.c
new file mode 100644
index 000000000..bc9d7ebd9
--- /dev/null
+++ b/drivers/soc/apple/t7000-ans-probe.c
@@ -0,0 +1,1149 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Probe-only helper for the Apple T7000 ANS/ASP storage path.
+ *
+ * This does not implement storage. It only proves whether Linux can bind
+ * to the ANS IOP node and power the domain that iOS uses for ASPStorage.
+ */
+
+#include <linux/ioport.h>
+#include <linux/io.h>
+#include <linux/mod_devicetable.h>
+#include <linux/module.h>
+#include <linux/platform_device.h>
+#include <linux/pm_runtime.h>
+#include <linux/slab.h>
+#include <linux/string.h>
+#include <linux/delay.h>
+
+#define ASC_A2I_CONTROL		0x110
+#define ASC_I2A_CONTROL		0x114
+#define ASC_A2I_SEND0		0x800
+#define ASC_A2I_SEND1		0x808
+#define ASC_I2A_RECV0		0x830
+#define ASC_I2A_RECV1		0x838
+#define ASC_CONTROL_FULL	BIT(16)
+#define ASC_CONTROL_EMPTY	BIT(17)
+#define ASC_CPU_CONTROL		0x044
+#define ASC_CPU_CONTROL_START	BIT(4)
+#define RTKIT_MGMT_TYPE(type)	((u64)(type) << 52)
+#define RTKIT_MGMT_EP		0
+#define RTKIT_MSG_HELLO		1
+#define RTKIT_MSG_HELLO_ACK	2
+#define RTKIT_MSG_IOP_PWR	6
+#define RTKIT_PWR_INIT		0x220
+#define AKF_BASE		0x1000
+#define AKF_A2I_CONTROL		(AKF_BASE + 0x08)
+#define AKF_A2I_SEND0		(AKF_BASE + 0x10)
+#define AKF_A2I_SEND1		(AKF_BASE + 0x14)
+#define AKF_I2A_CONTROL		(AKF_BASE + 0x20)
+#define AKF_I2A_RECV0		(AKF_BASE + 0x38)
+#define AKF_I2A_RECV1		(AKF_BASE + 0x3c)
+#define AKF_CONTROL_FULL	BIT(16)
+#define AKF_CONTROL_EMPTY	BIT(17)
+#define AKF_KNOWN_BOOT_0	0x0600000000000012ULL
+#define AKF_KNOWN_BOOT_1	0x0600000000000004ULL
+#define AKF_KNOWN_BOOT_2	0x00b0000000000010ULL
+#define AKF_KNOWN_BOOT_3	0x0070000000000001ULL
+
+enum t7000_oldrtb_phase {
+	OLDRTB_PHASE_UNKNOWN,
+	OLDRTB_PHASE_IOP_STATE_12,
+	OLDRTB_PHASE_IOP_STATE_04,
+	OLDRTB_PHASE_AP_POWER_10,
+	OLDRTB_PHASE_IOP_ACK_01,
+	OLDRTB_PHASE_LOOPING,
+};
+
+struct t7000_oldrtb_state {
+	enum t7000_oldrtb_phase phase;
+	u64 last_msg;
+	u32 samples;
+	u32 unknown;
+	u32 loop_count;
+	u32 repeat_state12;
+	u32 seen_mask;
+	u16 iop_state;
+	u16 ap_power_state;
+	u16 iop_ack_state;
+	u32 last_a2i_ctl;
+	u32 last_i2a_ctl;
+};
+
+struct apple_t7000_ans {
+	struct device *dev;
+	void __iomem *regs;
+	resource_size_t size;
+	int pm_ret;
+	struct t7000_oldrtb_state oldrtb;
+};
+
+static u64 akf_read_recv(struct apple_t7000_ans *ans)
+{
+	u32 recv0 = readl(ans->regs + AKF_I2A_RECV0);
+	u32 recv1 = readl(ans->regs + AKF_I2A_RECV1);
+
+	return ((u64)recv1 << 32) | recv0;
+}
+
+static void akf_write_send(struct apple_t7000_ans *ans, u64 msg)
+{
+	writel((u32)msg, ans->regs + AKF_A2I_SEND0);
+	writel((u32)(msg >> 32), ans->regs + AKF_A2I_SEND1);
+}
+
+static const char *akf_known_msg_name(u64 msg)
+{
+	switch (msg) {
+	case AKF_KNOWN_BOOT_0:
+		return "observed-boot-0/repeated-state";
+	case AKF_KNOWN_BOOT_1:
+		return "observed-boot-1/state-change";
+	case AKF_KNOWN_BOOT_2:
+		return "observed-boot-2/ap-power";
+	case AKF_KNOWN_BOOT_3:
+		return "observed-boot-3/iop-power-ack";
+	default:
+		return "unknown";
+	}
+}
+
+static const char *akf_mgmt_type_name(u8 type)
+{
+	switch (type) {
+	case 0x60:
+		return "old-iop-state/version-candidate";
+	case 0x0b:
+		return "ap-power-state";
+	case 0x07:
+		return "iop-power-ack";
+	default:
+		return "unknown";
+	}
+}
+
+static const char *oldrtb_phase_name(enum t7000_oldrtb_phase phase)
+{
+	switch (phase) {
+	case OLDRTB_PHASE_IOP_STATE_12:
+		return "iop-state-0x12";
+	case OLDRTB_PHASE_IOP_STATE_04:
+		return "iop-state-0x04";
+	case OLDRTB_PHASE_AP_POWER_10:
+		return "ap-power-0x10";
+	case OLDRTB_PHASE_IOP_ACK_01:
+		return "iop-ack-0x01";
+	case OLDRTB_PHASE_LOOPING:
+		return "stable-management-loop";
+	case OLDRTB_PHASE_UNKNOWN:
+	default:
+		return "unknown";
+	}
+}
+
+static enum t7000_oldrtb_phase oldrtb_classify_msg(u64 msg)
+{
+	switch (msg) {
+	case AKF_KNOWN_BOOT_0:
+		return OLDRTB_PHASE_IOP_STATE_12;
+	case AKF_KNOWN_BOOT_1:
+		return OLDRTB_PHASE_IOP_STATE_04;
+	case AKF_KNOWN_BOOT_2:
+		return OLDRTB_PHASE_AP_POWER_10;
+	case AKF_KNOWN_BOOT_3:
+		return OLDRTB_PHASE_IOP_ACK_01;
+	default:
+		return OLDRTB_PHASE_UNKNOWN;
+	}
+}
+
+static void oldrtb_reset_state(struct t7000_oldrtb_state *st)
+{
+	memset(st, 0, sizeof(*st));
+	st->phase = OLDRTB_PHASE_UNKNOWN;
+}
+
+static void oldrtb_update_state(struct t7000_oldrtb_state *st, u64 msg,
+				u32 a2i_ctl, u32 i2a_ctl)
+{
+	enum t7000_oldrtb_phase next = oldrtb_classify_msg(msg);
+	u16 low16 = msg;
+
+	st->samples++;
+	st->last_msg = msg;
+	st->last_a2i_ctl = a2i_ctl;
+	st->last_i2a_ctl = i2a_ctl;
+
+	switch (next) {
+	case OLDRTB_PHASE_IOP_STATE_12:
+		st->seen_mask |= BIT(0);
+		st->iop_state = low16;
+		if (st->phase == OLDRTB_PHASE_IOP_ACK_01 ||
+		    st->phase == OLDRTB_PHASE_LOOPING)
+			st->loop_count++;
+		else if (st->phase == OLDRTB_PHASE_IOP_STATE_12)
+			st->repeat_state12++;
+		break;
+	case OLDRTB_PHASE_IOP_STATE_04:
+		st->seen_mask |= BIT(1);
+		st->iop_state = low16;
+		break;
+	case OLDRTB_PHASE_AP_POWER_10:
+		st->seen_mask |= BIT(2);
+		st->ap_power_state = low16;
+		break;
+	case OLDRTB_PHASE_IOP_ACK_01:
+		st->seen_mask |= BIT(3);
+		st->iop_ack_state = low16;
+		if ((st->seen_mask & 0xf) == 0xf)
+			next = OLDRTB_PHASE_LOOPING;
+		break;
+	case OLDRTB_PHASE_UNKNOWN:
+	default:
+		st->unknown++;
+		break;
+	}
+
+	st->phase = next;
+}
+
+static int oldrtb_collect_state(struct apple_t7000_ans *ans,
+				struct t7000_oldrtb_state *st, int samples)
+{
+	u32 a2i_ctl;
+	u32 i2a_ctl;
+	u64 msg;
+	int i;
+
+	if (!ans || !ans->regs)
+		return -ENODEV;
+
+	oldrtb_reset_state(st);
+
+	for (i = 0; i < samples; i++) {
+		a2i_ctl = readl(ans->regs + AKF_A2I_CONTROL);
+		i2a_ctl = readl(ans->regs + AKF_I2A_CONTROL);
+		msg = akf_read_recv(ans);
+		oldrtb_update_state(st, msg, a2i_ctl, i2a_ctl);
+		usleep_range(1000, 2000);
+	}
+
+	ans->oldrtb = *st;
+
+	return 0;
+}
+
+static bool oldrtb_state_is_stable(const struct t7000_oldrtb_state *st)
+{
+	return st->samples && !st->unknown && (st->seen_mask & 0xf) == 0xf &&
+	       st->loop_count > 0;
+}
+
+static u64 oldrtb_phase_msg(enum t7000_oldrtb_phase phase)
+{
+	switch (phase) {
+	case OLDRTB_PHASE_IOP_STATE_12:
+		return AKF_KNOWN_BOOT_0;
+	case OLDRTB_PHASE_IOP_STATE_04:
+		return AKF_KNOWN_BOOT_1;
+	case OLDRTB_PHASE_AP_POWER_10:
+		return AKF_KNOWN_BOOT_2;
+	case OLDRTB_PHASE_IOP_ACK_01:
+		return AKF_KNOWN_BOOT_3;
+	default:
+		return 0;
+	}
+}
+
+static enum t7000_oldrtb_phase oldrtb_phase_from_token(const char *token)
+{
+	if (!strcmp(token, "state12") || !strcmp(token, "iop-state-0x12"))
+		return OLDRTB_PHASE_IOP_STATE_12;
+	if (!strcmp(token, "state04") || !strcmp(token, "iop-state-0x04"))
+		return OLDRTB_PHASE_IOP_STATE_04;
+	if (!strcmp(token, "ap_power10") || !strcmp(token, "ap-power-0x10"))
+		return OLDRTB_PHASE_AP_POWER_10;
+	if (!strcmp(token, "iop_ack01") || !strcmp(token, "iop-ack-0x01"))
+		return OLDRTB_PHASE_IOP_ACK_01;
+
+	return OLDRTB_PHASE_UNKNOWN;
+}
+
+static ssize_t akf_format_msg(char *buf, ssize_t len, int sample,
+			      u32 a2i_ctl, u32 i2a_ctl, u64 msg)
+{
+	u32 low = msg;
+	u32 high = msg >> 32;
+	u8 top = high >> 24;
+	u8 rtkit_type = high >> 20;
+	u8 mgmt_type = msg >> 52;
+	u8 mgmt_major = msg >> 60;
+	u8 mgmt_sub = (msg >> 48) & 0x0f;
+	u16 low16 = low;
+	u32 payload = low & 0x00ffffff;
+	u8 b7 = msg >> 56;
+	u8 b6 = msg >> 48;
+	u8 b5 = msg >> 40;
+	u8 b4 = msg >> 32;
+	u8 b3 = msg >> 24;
+	u8 b2 = msg >> 16;
+	u8 b1 = msg >> 8;
+	u8 b0 = msg;
+
+	return len + sysfs_emit_at(buf, len,
+				   "%02d a2i=%08x i2a=%08x empty=%u full=%u msg=%016llx bytes=%02x:%02x:%02x:%02x:%02x:%02x:%02x:%02x hi=%08x lo=%08x top=%02x rtkit_type=%02x mgmt_type=%02x major=%x sub=%x low16=%04x payload=%06x low8=%02x name=%s known=%s\n",
+				   sample, a2i_ctl, i2a_ctl,
+				   !!(i2a_ctl & AKF_CONTROL_EMPTY),
+				   !!(i2a_ctl & AKF_CONTROL_FULL),
+				   msg, b7, b6, b5, b4, b3, b2, b1, b0,
+				   high, low, top, rtkit_type, mgmt_type,
+				   mgmt_major, mgmt_sub, low16, payload, b0,
+				   akf_mgmt_type_name(mgmt_type),
+				   akf_known_msg_name(msg));
+}
+
+static ssize_t regs_show(struct device *dev, struct device_attribute *attr, char *buf)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	ssize_t len = 0;
+	u32 val;
+	int i;
+
+	if (!ans || !ans->regs)
+		return sysfs_emit(buf, "no-mmio\n");
+
+	for (i = 0; i < 16 && (i * 4) < ans->size; i++) {
+		val = readl(ans->regs + i * 4);
+		len += sysfs_emit_at(buf, len, "%03x: %08x\n", i * 4, val);
+	}
+
+	return len;
+}
+static DEVICE_ATTR_RO(regs);
+
+static ssize_t mbox_show(struct device *dev, struct device_attribute *attr, char *buf)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	ssize_t len = 0;
+	static const struct {
+		const char *name;
+		u32 off;
+		bool is64;
+	} regs[] = {
+		{ "asc_a2i_control", 0x110, false },
+		{ "asc_i2a_control", 0x114, false },
+		{ "asc_a2i_send0", 0x800, true },
+		{ "asc_a2i_send1", 0x808, true },
+		{ "asc_i2a_recv0", 0x830, true },
+		{ "asc_i2a_recv1", 0x838, true },
+		{ "m3_irq_enable", 0x048, false },
+		{ "m3_irq_ack", 0x04c, false },
+		{ "m3_a2i_control", 0x050, false },
+		{ "m3_a2i_send0", 0x060, true },
+		{ "m3_a2i_send1", 0x068, true },
+		{ "m3_i2a_control", 0x080, false },
+		{ "m3_i2a_recv0", 0x0a0, true },
+		{ "m3_i2a_recv1", 0x0a8, true },
+	};
+	int i;
+
+	if (!ans || !ans->regs)
+		return sysfs_emit(buf, "no-mmio\n");
+
+	for (i = 0; i < ARRAY_SIZE(regs); i++) {
+		if (regs[i].off + (regs[i].is64 ? 8 : 4) > ans->size)
+			continue;
+
+		if (regs[i].is64)
+			len += sysfs_emit_at(buf, len, "%-16s @%03x: %016llx\n",
+					     regs[i].name, regs[i].off,
+					     readq(ans->regs + regs[i].off));
+		else
+			len += sysfs_emit_at(buf, len, "%-16s @%03x: %08x\n",
+					     regs[i].name, regs[i].off,
+					     readl(ans->regs + regs[i].off));
+	}
+
+	return len;
+}
+static DEVICE_ATTR_RO(mbox);
+
+static ssize_t akf_mbox_show(struct device *dev, struct device_attribute *attr, char *buf)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	ssize_t len = 0;
+	static const struct {
+		const char *name;
+		u32 off;
+	} regs[] = {
+		{ "akf_set", AKF_BASE + 0x00 },
+		{ "akf_clr", AKF_BASE + 0x04 },
+		{ "akf_a2i_control", AKF_A2I_CONTROL },
+		{ "akf_a2i_send0", AKF_A2I_SEND0 },
+		{ "akf_a2i_send1", AKF_A2I_SEND1 },
+		{ "akf_a2i_recv0", AKF_BASE + 0x18 },
+		{ "akf_a2i_recv1", AKF_BASE + 0x1c },
+		{ "akf_i2a_control", AKF_I2A_CONTROL },
+		{ "akf_i2a_send0", AKF_BASE + 0x30 },
+		{ "akf_i2a_send1", AKF_BASE + 0x34 },
+		{ "akf_i2a_recv0", AKF_I2A_RECV0 },
+		{ "akf_i2a_recv1", AKF_I2A_RECV1 },
+	};
+	int i;
+
+	if (!ans || !ans->regs)
+		return sysfs_emit(buf, "no-mmio\n");
+
+	for (i = 0; i < ARRAY_SIZE(regs); i++) {
+		if (regs[i].off + 4 > ans->size)
+			continue;
+
+		len += sysfs_emit_at(buf, len, "%-16s @%03x: %08x\n",
+				     regs[i].name, regs[i].off,
+				     readl(ans->regs + regs[i].off));
+	}
+
+	return len;
+}
+static DEVICE_ATTR_RO(akf_mbox);
+
+static ssize_t rxpoll_show(struct device *dev, struct device_attribute *attr, char *buf)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	ssize_t len = 0;
+	u32 a2i_ctl;
+	u32 i2a_ctl;
+	u64 recv0;
+	u64 recv1;
+	int i;
+
+	if (!ans || !ans->regs)
+		return sysfs_emit(buf, "no-mmio\n");
+
+	len += sysfs_emit_at(buf, len,
+			     "sample a2i_ctl i2a_ctl i2a_empty i2a_full recv0 recv1\n");
+
+	for (i = 0; i < 8; i++) {
+		a2i_ctl = readl(ans->regs + ASC_A2I_CONTROL);
+		i2a_ctl = readl(ans->regs + ASC_I2A_CONTROL);
+		recv0 = readq(ans->regs + ASC_I2A_RECV0);
+		recv1 = readq(ans->regs + ASC_I2A_RECV1);
+
+		len += sysfs_emit_at(buf, len,
+				     "%02d     %08x %08x %u         %u        %016llx %016llx\n",
+				     i, a2i_ctl, i2a_ctl,
+				     !!(i2a_ctl & ASC_CONTROL_EMPTY),
+				     !!(i2a_ctl & ASC_CONTROL_FULL), recv0, recv1);
+		usleep_range(1000, 2000);
+	}
+
+	return len;
+}
+static DEVICE_ATTR_RO(rxpoll);
+
+static ssize_t akf_rxpoll_show(struct device *dev, struct device_attribute *attr, char *buf)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	ssize_t len = 0;
+	u32 a2i_ctl;
+	u32 i2a_ctl;
+	u32 recv0;
+	u32 recv1;
+	int i;
+
+	if (!ans || !ans->regs)
+		return sysfs_emit(buf, "no-mmio\n");
+
+	len += sysfs_emit_at(buf, len,
+			     "sample a2i_ctl i2a_ctl i2a_empty i2a_full recv0 recv1 combined ep type\n");
+
+	for (i = 0; i < 8; i++) {
+		a2i_ctl = readl(ans->regs + AKF_A2I_CONTROL);
+		i2a_ctl = readl(ans->regs + AKF_I2A_CONTROL);
+		recv0 = readl(ans->regs + AKF_I2A_RECV0);
+		recv1 = readl(ans->regs + AKF_I2A_RECV1);
+
+		len += sysfs_emit_at(buf, len,
+				     "%02d     %08x %08x %u         %u        %08x %08x %016llx %02x %02x\n",
+				     i, a2i_ctl, i2a_ctl,
+				     !!(i2a_ctl & AKF_CONTROL_EMPTY),
+				     !!(i2a_ctl & AKF_CONTROL_FULL),
+				     recv0, recv1,
+				     ((u64)recv1 << 32) | recv0,
+				     recv1 & 0xff, recv1 >> 20);
+		usleep_range(1000, 2000);
+	}
+
+	return len;
+}
+static DEVICE_ATTR_RO(akf_rxpoll);
+
+static ssize_t akf_decode_show(struct device *dev, struct device_attribute *attr, char *buf)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	ssize_t len = 0;
+	u32 a2i_ctl;
+	u32 i2a_ctl;
+	u64 msg;
+	int i;
+
+	if (!ans || !ans->regs)
+		return sysfs_emit(buf, "no-mmio\n");
+
+	len += sysfs_emit_at(buf, len,
+			     "known sequence: %016llx -> %016llx -> %016llx -> %016llx\n",
+			     AKF_KNOWN_BOOT_0, AKF_KNOWN_BOOT_1,
+			     AKF_KNOWN_BOOT_2, AKF_KNOWN_BOOT_3);
+	len += sysfs_emit_at(buf, len,
+			     "fields: mgmt_type=msg[59:52], major=msg[63:60], sub=msg[51:48], low16=msg[15:0]\n");
+	len += sysfs_emit_at(buf, len,
+			     "note: local iOS 12.5.8 RTBuddyManagementEndpoint has old-format branches; this decoder only labels candidates and does not send replies\n");
+
+	for (i = 0; i < 16; i++) {
+		a2i_ctl = readl(ans->regs + AKF_A2I_CONTROL);
+		i2a_ctl = readl(ans->regs + AKF_I2A_CONTROL);
+		msg = akf_read_recv(ans);
+		len = akf_format_msg(buf, len, i, a2i_ctl, i2a_ctl, msg);
+		usleep_range(1000, 2000);
+	}
+
+	return len;
+}
+static DEVICE_ATTR_RO(akf_decode);
