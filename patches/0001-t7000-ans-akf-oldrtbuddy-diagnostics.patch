+static ssize_t rtkit_wake_show(struct device *dev, struct device_attribute *attr, char *buf)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	ssize_t len = 0;
+	u32 cpu_before;
+	u32 cpu_after;
+	u32 a2i_ctl;
+	u32 i2a_ctl;
+	u64 recv0;
+	u64 recv1;
+	u64 wake = RTKIT_MGMT_TYPE(RTKIT_MSG_IOP_PWR) | RTKIT_PWR_INIT;
+	int i;
+
+	if (!ans || !ans->regs)
+		return sysfs_emit(buf, "no-mmio\n");
+
+	cpu_before = readl(ans->regs + ASC_CPU_CONTROL);
+	writel(cpu_before | ASC_CPU_CONTROL_START, ans->regs + ASC_CPU_CONTROL);
+	cpu_after = readl(ans->regs + ASC_CPU_CONTROL);
+
+	a2i_ctl = readl(ans->regs + ASC_A2I_CONTROL);
+	len += sysfs_emit_at(buf, len,
+			     "cpu_before=%08x cpu_after=%08x a2i_ctl_before=%08x\n",
+			     cpu_before, cpu_after, a2i_ctl);
+
+	if (a2i_ctl & ASC_CONTROL_FULL)
+		return sysfs_emit_at(buf, len, "send=busy\n");
+
+	len += sysfs_emit_at(buf, len, "send msg0=%016llx msg1=%016x\n",
+			     wake, RTKIT_MGMT_EP);
+	writeq(wake, ans->regs + ASC_A2I_SEND0);
+	writeq(RTKIT_MGMT_EP, ans->regs + ASC_A2I_SEND1);
+
+	len += sysfs_emit_at(buf, len,
+			     "sample i2a_ctl empty full recv0 recv1 ep type hello\n");
+	for (i = 0; i < 32; i++) {
+		i2a_ctl = readl(ans->regs + ASC_I2A_CONTROL);
+		recv0 = readq(ans->regs + ASC_I2A_RECV0);
+		recv1 = readq(ans->regs + ASC_I2A_RECV1);
+
+		len += sysfs_emit_at(buf, len,
+				     "%02d     %08x %u     %u    %016llx %016llx %02llx %02llx %u\n",
+				     i, i2a_ctl,
+				     !!(i2a_ctl & ASC_CONTROL_EMPTY),
+				     !!(i2a_ctl & ASC_CONTROL_FULL),
+				     recv0, recv1, recv1 & 0xff, (recv0 >> 52) & 0xff,
+				     (u32)((recv1 & 0xff) == RTKIT_MGMT_EP &&
+					   ((recv0 >> 52) & 0xff) == RTKIT_MSG_HELLO));
+		if ((recv1 & 0xff) == RTKIT_MGMT_EP &&
+		    ((recv0 >> 52) & 0xff) == RTKIT_MSG_HELLO)
+			break;
+
+		usleep_range(5000, 7000);
+	}
+
+	return len;
+}
+static DEVICE_ATTR_RO(rtkit_wake);
+
+static ssize_t akf_rtkit_wake_show(struct device *dev, struct device_attribute *attr, char *buf)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	ssize_t len = 0;
+	u32 a2i_ctl;
+	u32 i2a_ctl;
+	u32 recv0;
+	u32 recv1;
+	u64 recv;
+	u64 wake = RTKIT_MGMT_TYPE(RTKIT_MSG_IOP_PWR) | RTKIT_PWR_INIT;
+	int i;
+
+	if (!ans || !ans->regs)
+		return sysfs_emit(buf, "no-mmio\n");
+
+	a2i_ctl = readl(ans->regs + AKF_A2I_CONTROL);
+	len += sysfs_emit_at(buf, len, "akf_a2i_ctl_before=%08x\n", a2i_ctl);
+	if (a2i_ctl & AKF_CONTROL_FULL)
+		return sysfs_emit_at(buf, len, "send=busy\n");
+
+	len += sysfs_emit_at(buf, len, "send split msg0=%08x msg1=%08x combined=%016llx\n",
+			     (u32)wake, (u32)(wake >> 32), wake);
+	writel((u32)wake, ans->regs + AKF_A2I_SEND0);
+	writel((u32)(wake >> 32), ans->regs + AKF_A2I_SEND1);
+
+	len += sysfs_emit_at(buf, len,
+			     "sample i2a_ctl empty full recv0 recv1 combined ep type hello\n");
+	for (i = 0; i < 32; i++) {
+		i2a_ctl = readl(ans->regs + AKF_I2A_CONTROL);
+		recv0 = readl(ans->regs + AKF_I2A_RECV0);
+		recv1 = readl(ans->regs + AKF_I2A_RECV1);
+		recv = ((u64)recv1 << 32) | recv0;
+
+		len += sysfs_emit_at(buf, len,
+				     "%02d     %08x %u     %u    %08x %08x %016llx %02x %02llx %u\n",
+				     i, i2a_ctl,
+				     !!(i2a_ctl & AKF_CONTROL_EMPTY),
+				     !!(i2a_ctl & AKF_CONTROL_FULL),
+				     recv0, recv1, recv, recv1 & 0xff,
+				     (recv >> 52) & 0xff,
+				     (u32)((recv1 & 0xff) == RTKIT_MGMT_EP &&
+					   ((recv >> 52) & 0xff) == RTKIT_MSG_HELLO));
+		if ((recv1 & 0xff) == RTKIT_MGMT_EP &&
+		    ((recv >> 52) & 0xff) == RTKIT_MSG_HELLO)
+			break;
+
+		usleep_range(5000, 7000);
+	}
+
+	return len;
+}
+static DEVICE_ATTR_RO(akf_rtkit_wake);
