+	len += sysfs_emit_at(buf, len,
+			     "phases: state12 expects %016llx, state04 expects %016llx, ap_power10 expects %016llx, iop_ack01 expects %016llx\n",
+			     AKF_KNOWN_BOOT_0, AKF_KNOWN_BOOT_1,
+			     AKF_KNOWN_BOOT_2, AKF_KNOWN_BOOT_3);
+	len += sysfs_emit_at(buf, len,
+			     "guard=requires stable four-message management loop, matching current phase, exact expected message, and non-full AP-to-IOP mailbox\n");
+	len += sysfs_emit_at(buf, len,
+			     "next=use this only for ordered RTBuddy management experiments before ANSEndpoint1/ASPStorage work\n");
