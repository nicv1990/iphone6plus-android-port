+	ret = oldrtb_collect_state(ans, &st, 64);
+	if (ret)
+		return ret;
+
+	len += sysfs_emit_at(buf, len, "oldrtbuddy_state=v1\n");
+	len += sysfs_emit_at(buf, len, "samples=%u unknown=%u phase=%s last_msg=%016llx\n",
+			     st.samples, st.unknown, oldrtb_phase_name(st.phase),
+			     st.last_msg);
+	len += sysfs_emit_at(buf, len,
+			     "seen: state12=%u state04=%u ap_power10=%u iop_ack01=%u mask=%x\n",
+			     !!(st.seen_mask & BIT(0)), !!(st.seen_mask & BIT(1)),
+			     !!(st.seen_mask & BIT(2)), !!(st.seen_mask & BIT(3)),
+			     st.seen_mask);
+	len += sysfs_emit_at(buf, len,
+			     "loop_count=%u repeat_state12=%u iop_state=%04x ap_power_state=%04x iop_ack_state=%04x\n",
+			     st.loop_count, st.repeat_state12, st.iop_state,
+			     st.ap_power_state, st.iop_ack_state);
+	len += sysfs_emit_at(buf, len,
+			     "last_controls: a2i=%08x i2a=%08x i2a_empty=%u i2a_full=%u\n",
+			     st.last_a2i_ctl, st.last_i2a_ctl,
+			     !!(st.last_i2a_ctl & AKF_CONTROL_EMPTY),
+			     !!(st.last_i2a_ctl & AKF_CONTROL_FULL));
+	len += sysfs_emit_at(buf, len,
+			     "interpretation=%s\n",
+			     oldrtb_state_is_stable(&st) ?
+			     "controller is alive but still cycling in old RTBuddy management; endpoint map/start not reached" :
+			     "unexpected traffic observed; inspect akf_decode before sending anything");
+	len += sysfs_emit_at(buf, len,
+			     "next_code_step=use oldrtbuddy_plan and oldrtbuddy_ordered_reply for gated management replies, then ANSEndpoint1 start before ASPStorage block commands\n");
+
+	return len;
+}
