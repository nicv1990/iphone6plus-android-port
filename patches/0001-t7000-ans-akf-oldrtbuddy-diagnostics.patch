+static ssize_t oldrtbuddy_packet_addr_send_store(struct device *dev,
+						 struct device_attribute *attr,
+						 const char *buf, size_t count)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	const struct t7000_oldrtb_packet_variant *variant;
+	struct t7000_oldrtb_state st;
+	char variant_name[32];
+	char candidate_name[32];
+	u32 a2i_ctl;
+	u64 msg;
+	int ret;
+
+	if (!ans || !ans->regs)
+		return -ENODEV;
+
+	ret = sscanf(buf, "%31s %31s", variant_name, candidate_name);
+	if (ret != 2)
+		return -EINVAL;
+
+	variant = oldrtb_packet_variant_by_name(variant_name);
+	if (!variant)
+		return -EINVAL;
+
+	ret = oldrtb_collect_state(ans, &st, 64);
+	if (ret)
+		return ret;
+	if (!oldrtb_state_is_stable(&st)) {
+		dev_notice(dev,
+			   "T7000 ANS old RTBuddy packet addr send refused: phase=%s seen_mask=%x unknown=%u loop_count=%u\n",
+			   oldrtb_phase_name(st.phase), st.seen_mask,
+			   st.unknown, st.loop_count);
+		return -EAGAIN;
+	}
+
+	ret = oldrtb_stage_packet(ans, variant);
+	if (ret)
+		return ret;
+
+	ret = oldrtb_addr_candidate_msg(candidate_name, ans->oldrtb_dma_addr,
+					ans->oldrtb_packet_len, &msg);
+	if (ret)
+		return ret;
+
+	a2i_ctl = readl(ans->regs + AKF_A2I_CONTROL);
+	if (a2i_ctl & AKF_CONTROL_FULL)
+		return -EBUSY;
+
+	strscpy(ans->oldrtb_addr_last, candidate_name,
+		sizeof(ans->oldrtb_addr_last));
+	ans->oldrtb_addr_last_msg = msg;
+	ans->oldrtb_addr_last_a2i_ctl = a2i_ctl;
+	ans->oldrtb_addr_last_len = ans->oldrtb_packet_len;
+
+	dev_notice(dev,
+		   "T7000 ANS old RTBuddy packet addr send: variant=%s candidate=%s msg=%016llx addr=%pad len=0x%zx a2i_ctl=%08x\n",
+		   variant->name, candidate_name, msg, &ans->oldrtb_dma_addr,
+		   ans->oldrtb_packet_len, a2i_ctl);
+	akf_write_send(ans, msg);
+
+	return count;
+}
+static DEVICE_ATTR_WO(oldrtbuddy_packet_addr_send);
+
+static ssize_t oldrtbuddy_state_show(struct device *dev,
+				     struct device_attribute *attr, char *buf)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	struct t7000_oldrtb_state st;
+	ssize_t len = 0;
+	int ret;
+
+	if (!ans || !ans->regs)
+		return sysfs_emit(buf, "no-mmio\n");
+
+	ret = oldrtb_collect_state(ans, &st, 64);
+	if (ret)
+		return ret;
+
+	len += sysfs_emit_at(buf, len, "oldrtbuddy_state=v1\n");
+	len += sysfs_emit_at(buf, len, "samples=%u unknown=%u phase=%s last_msg=%016llx\n",
+			     st.samples, st.unknown, oldrtb_phase_name(st.phase),
+			     st.last_msg);
+	len += sysfs_emit_at(buf, len,
+			     "seen: state12=%u state04=%u ap_power10=%u iop_ack01=%u mask=%x\n",
+			     !!(st.seen_mask & BIT(0)), !!(st.seen_mask & BIT(1)),
+			     !!(st.seen_mask & BIT(2)), !!(st.seen_mask & BIT(3)),
+			     st.seen_mask);
+	len += sysfs_emit_at(buf, len,
+			     "loop_count=%u repeat_state12=%u iop_state=%04x ap_power_state=%04x iop_ack_state=%04x\n",
+			     st.loop_count, st.repeat_state12, st.iop_state,
+			     st.ap_power_state, st.iop_ack_state);
+	len += sysfs_emit_at(buf, len,
+			     "last_controls: a2i=%08x i2a=%08x i2a_empty=%u i2a_full=%u\n",
+			     st.last_a2i_ctl, st.last_i2a_ctl,
+			     !!(st.last_i2a_ctl & AKF_CONTROL_EMPTY),
+			     !!(st.last_i2a_ctl & AKF_CONTROL_FULL));
+	len += sysfs_emit_at(buf, len,
+			     "interpretation=%s\n",
+			     oldrtb_state_is_stable(&st) ?
+			     "controller is alive but still cycling in old RTBuddy management; endpoint map/start not reached" :
+			     "unexpected traffic observed; inspect akf_decode before sending anything");
+	len += sysfs_emit_at(buf, len,
+			     "next_code_step=reconstruct the old RTBuddy shared-buffer transaction header/callback flow, then start ANSEndpoint1 before ASPStorage block commands\n");
+
+	return len;
+}
+static DEVICE_ATTR_RO(oldrtbuddy_state);
