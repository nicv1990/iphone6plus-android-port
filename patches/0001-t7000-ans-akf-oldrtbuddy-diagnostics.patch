+static ssize_t oldrtbuddy_packet_stage_store(struct device *dev,
+					     struct device_attribute *attr,
+					     const char *buf, size_t count)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	const struct t7000_oldrtb_packet_variant *variant;
+	char name[32];
+	int ret;
+
+	if (!ans)
+		return -ENODEV;
+
+	ret = sscanf(buf, "%31s", name);
+	if (ret != 1)
+		return -EINVAL;
+
+	variant = oldrtb_packet_variant_by_name(name);
+	if (!variant)
+		return -EINVAL;
+
+	ret = oldrtb_stage_packet(ans, variant);
+	if (ret)
+		return ret;
+
+	dev_notice(dev,
+		   "T7000 ANS old RTBuddy packet staged: name=%s seq=%u format=0x%02x len=0x%zx word0=0x%08x word1=0x%08x dma=%pad\n",
+		   variant->name, ans->oldrtb_packet_seq, ans->oldrtb_packet_format,
+		   ans->oldrtb_packet_len, variant->word0, variant->word1,
+		   &ans->oldrtb_dma_addr);
+
+	return count;
+}
