+static int oldrtb_ensure_dma_packet(struct apple_t7000_ans *ans)
+{
+	if (ans->oldrtb_dma_packet)
+		return 0;
+
+	ans->oldrtb_dma_size = OLDRTB_PKT_MAX;
+	ans->oldrtb_dma_packet = dma_alloc_coherent(ans->dev,
+						    ans->oldrtb_dma_size,
+						    &ans->oldrtb_dma_addr,
+						    GFP_KERNEL);
+	if (ans->oldrtb_dma_packet) {
+		ans->oldrtb_dma_coherent = true;
+		dev_notice(ans->dev,
+			   "T7000 ANS old RTBuddy coherent packet buffer: dma=%pad size=0x%zx\n",
+			   &ans->oldrtb_dma_addr, ans->oldrtb_dma_size);
+		return 0;
+	}
+
+	/*
+	 * The early bring-up ramdisk can lack usable coherent DMA memory for
+	 * this platform device. Keep a physical-address fallback so the packet
+	 * layout and address-passing model can still be tested on hardware.
+	 */
+	ans->oldrtb_dma_size = PAGE_SIZE;
+	ans->oldrtb_dma_packet = (void *)get_zeroed_page(GFP_KERNEL | GFP_DMA);
+	if (!ans->oldrtb_dma_packet)
+		ans->oldrtb_dma_packet = (void *)get_zeroed_page(GFP_KERNEL);
+	if (!ans->oldrtb_dma_packet) {
+		ans->oldrtb_dma_size = 0;
+		return -ENOMEM;
+	}
+
+	ans->oldrtb_dma_addr = (dma_addr_t)virt_to_phys(ans->oldrtb_dma_packet);
+	ans->oldrtb_dma_coherent = false;
+	dev_notice(ans->dev,
+		   "T7000 ANS old RTBuddy physical packet buffer fallback: phys=%pad size=0x%zx\n",
+		   &ans->oldrtb_dma_addr, ans->oldrtb_dma_size);
+
+	return 0;
+}
+
+static int oldrtb_stage_packet(struct apple_t7000_ans *ans,
+			       const struct t7000_oldrtb_packet_variant *variant)
+{
+	u32 i;
+	int ret;
+
+	memset(ans->oldrtb_packet, 0, sizeof(ans->oldrtb_packet));
+
+	memcpy(ans->oldrtb_packet, oldrtb_packet_prefix, sizeof(oldrtb_packet_prefix));
+	memcpy(ans->oldrtb_packet + 0x08, &variant->word0, sizeof(variant->word0));
+	memcpy(ans->oldrtb_packet + 0x0c, &variant->word1, sizeof(variant->word1));
+
+	for (i = 0; i < variant->payload_len; i++)
+		ans->oldrtb_packet[OLDRTB_PKT_HDR_SIZE + i] =
+			(u8)(i ^ variant->word0 ^ variant->word1);
+
+	ans->oldrtb_packet_len = variant->total_len;
+	ans->oldrtb_packet_format = variant->format;
+	ans->oldrtb_packet_seq++;
+
+	ret = oldrtb_ensure_dma_packet(ans);
+	if (ret)
+		return ret;
+
+	memset(ans->oldrtb_dma_packet, 0, ans->oldrtb_dma_size);
+	memcpy(ans->oldrtb_dma_packet, ans->oldrtb_packet,
+	       ans->oldrtb_packet_len);
+
+	return 0;
+}
+
+static const struct t7000_oldrtb_packet_variant *
+oldrtb_packet_variant_by_name(const char *name)
+{
+	int i;
+
+	for (i = 0; i < ARRAY_SIZE(oldrtb_packet_variants); i++) {
+		if (!strcmp(name, oldrtb_packet_variants[i].name))
+			return &oldrtb_packet_variants[i];
+	}
+
+	return NULL;
+}
