+static void apple_t7000_ans_remove(struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+
+	device_remove_file(dev, &dev_attr_akf_rtkit_wake);
+	device_remove_file(dev, &dev_attr_rtkit_wake);
+	device_remove_file(dev, &dev_attr_akf_send_if_current);
+	device_remove_file(dev, &dev_attr_akf_send_raw);
+	device_remove_file(dev, &dev_attr_send_raw);
+	device_remove_file(dev, &dev_attr_oldrtbuddy_packet_addr_send);
+	device_remove_file(dev, &dev_attr_oldrtbuddy_packet_addr_plan);
+	device_remove_file(dev, &dev_attr_oldrtbuddy_packet_dump);
+	device_remove_file(dev, &dev_attr_oldrtbuddy_packet_stage);
+	device_remove_file(dev, &dev_attr_oldrtbuddy_packet_model);
+	device_remove_file(dev, &dev_attr_oldrtbuddy_transaction);
+	device_remove_file(dev, &dev_attr_oldrtbuddy_transaction_plan);
+	device_remove_file(dev, &dev_attr_oldrtbuddy_ordered_reply);
+	device_remove_file(dev, &dev_attr_oldrtbuddy_plan);
+	device_remove_file(dev, &dev_attr_oldrtbuddy_state);
+	device_remove_file(dev, &dev_attr_akf_decode);
+	device_remove_file(dev, &dev_attr_akf_rxpoll);
+	device_remove_file(dev, &dev_attr_rxpoll);
+	device_remove_file(dev, &dev_attr_akf_mbox);
+	device_remove_file(dev, &dev_attr_mbox);
+	device_remove_file(dev, &dev_attr_state);
+	device_remove_file(dev, &dev_attr_regs);
+	if (ans->oldrtb_dma_packet) {
+		if (ans->oldrtb_dma_coherent)
+			dma_free_coherent(dev, ans->oldrtb_dma_size,
+					  ans->oldrtb_dma_packet,
+					  ans->oldrtb_dma_addr);
+		else
+			free_page((unsigned long)ans->oldrtb_dma_packet);
+	}
+	pm_runtime_put_sync(dev);
+	pm_runtime_disable(dev);
+}
