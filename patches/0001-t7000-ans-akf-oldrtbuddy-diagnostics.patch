+static ssize_t oldrtbuddy_ordered_reply_store(struct device *dev,
+					      struct device_attribute *attr,
+					      const char *buf, size_t count)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	struct t7000_oldrtb_state st;
+	enum t7000_oldrtb_phase phase;
+	char phase_token[32];
+	u64 expected;
+	u64 reply;
+	u64 cur_msg;
+	u32 a2i_ctl;
+	int ret;
+
+	if (!ans || !ans->regs)
+		return -ENODEV;
+
+	ret = sscanf(buf, "%31s %llx", phase_token, &reply);
+	if (ret != 2)
+		return -EINVAL;
+
+	phase = oldrtb_phase_from_token(phase_token);
+	expected = oldrtb_phase_msg(phase);
+	if (!expected)
+		return -EINVAL;
+
+	ret = oldrtb_collect_state(ans, &st, 64);
+	if (ret)
+		return ret;
+
+	if (!oldrtb_state_is_stable(&st)) {
+		dev_notice(dev,
+			   "T7000 ANS AKF ordered reply skipped: unstable loop samples=%u unknown=%u seen_mask=%x loop_count=%u\n",
+			   st.samples, st.unknown, st.seen_mask, st.loop_count);
+		return -EAGAIN;
+	}
+
+	cur_msg = akf_read_recv(ans);
+	if (oldrtb_classify_msg(cur_msg) != phase || cur_msg != expected) {
+		dev_notice(dev,
+			   "T7000 ANS AKF ordered reply skipped: cur_msg=%016llx cur_phase=%s requested_phase=%s expected=%016llx\n",
+			   cur_msg, oldrtb_phase_name(oldrtb_classify_msg(cur_msg)),
+			   oldrtb_phase_name(phase), expected);
+		return -EAGAIN;
+	}
+
+	a2i_ctl = readl(ans->regs + AKF_A2I_CONTROL);
+	if (a2i_ctl & AKF_CONTROL_FULL)
+		return -EBUSY;
+
+	dev_notice(dev,
+		   "T7000 ANS AKF ordered reply: stable loop_count=%u phase=%s expected=%016llx reply=%016llx a2i_ctl=%08x\n",
+		   st.loop_count, oldrtb_phase_name(phase), expected, reply,
+		   a2i_ctl);
+	akf_write_send(ans, reply);
+
+	return count;
+}
+static DEVICE_ATTR_WO(oldrtbuddy_ordered_reply);
+
