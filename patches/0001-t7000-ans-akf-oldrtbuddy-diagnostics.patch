+
+	len += sysfs_emit_at(buf, len,
+			     "oldrtbuddy_packet_dump=v1 seq=%u format=0x%02x len=0x%zx\n",
+			     ans->oldrtb_packet_seq, ans->oldrtb_packet_format,
+			     ans->oldrtb_packet_len);
+	len += sysfs_emit_at(buf, len,
+			     "dma_packet allocated=%u mode=%s addr=%pad size=0x%zx copied_len=0x%zx\n",
+			     !!ans->oldrtb_dma_packet,
+			     ans->oldrtb_dma_coherent ? "coherent" : "phys-fallback",
+			     &ans->oldrtb_dma_addr,
+			     ans->oldrtb_dma_size, ans->oldrtb_packet_len);
+	len += sysfs_emit_at(buf, len,
+			     "prefix_le=%02x%02x%02x%02x%02x%02x%02x%02x word0_le=%02x%02x%02x%02x word1_le=%02x%02x%02x%02x payload_status=diagnostic-pattern\n",
+			     ans->oldrtb_packet[0x00], ans->oldrtb_packet[0x01],
+			     ans->oldrtb_packet[0x02], ans->oldrtb_packet[0x03],
+			     ans->oldrtb_packet[0x04], ans->oldrtb_packet[0x05],
+			     ans->oldrtb_packet[0x06], ans->oldrtb_packet[0x07],
+			     ans->oldrtb_packet[0x08], ans->oldrtb_packet[0x09],
+			     ans->oldrtb_packet[0x0a], ans->oldrtb_packet[0x0b],
+			     ans->oldrtb_packet[0x0c], ans->oldrtb_packet[0x0d],
+			     ans->oldrtb_packet[0x0e], ans->oldrtb_packet[0x0f]);
+
+	for (i = 0; i < ans->oldrtb_packet_len; i += 16) {
+		size_t j;
+
+		len += sysfs_emit_at(buf, len, "%04zx:", i);
+		for (j = 0; j < 16 && i + j < ans->oldrtb_packet_len; j++)
+			len += sysfs_emit_at(buf, len, " %02x",
+					     ans->oldrtb_packet[i + j]);
+		len += sysfs_emit_at(buf, len, "\n");
+	}
+
+	return len;
+}
+static DEVICE_ATTR_RO(oldrtbuddy_packet_dump);
+
+static int oldrtb_addr_candidate_msg(const char *name, dma_addr_t addr,
+				     u32 packet_len, u64 *msg)
+{
+	u64 a = (u64)addr;
+
+	if (!strcmp(name, "addr64")) {
+		*msg = a;
+		return 0;
+	}
+	if (!strcmp(name, "addr-shift4")) {
+		*msg = a >> 4;
+		return 0;
+	}
+	if (!strcmp(name, "addr-shift12")) {
+		*msg = a >> 12;
+		return 0;
+	}
+	if (!strcmp(name, "addr-len")) {
+		*msg = ((u64)packet_len << 32) | (u32)a;
+		return 0;
+	}
+	if (!strcmp(name, "len-addr")) {
+		*msg = ((u64)(u32)a << 32) | packet_len;
+		return 0;
+	}
+
+	return -EINVAL;
+}
+
+static ssize_t oldrtbuddy_packet_addr_plan_show(struct device *dev,
+						struct device_attribute *attr,
+						char *buf)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	ssize_t len = 0;
+	size_t i;
+
+	if (!ans)
+		return sysfs_emit(buf, "no-state\n");
+
+	len += sysfs_emit_at(buf, len, "oldrtbuddy_packet_addr_plan=v1\n");
+	len += sysfs_emit_at(buf, len,
+			     "current_packet allocated=%u mode=%s addr=%pad len=0x%zx seq=%u format=0x%02x\n",
+			     !!ans->oldrtb_dma_packet,
+			     ans->oldrtb_dma_coherent ? "coherent" : "phys-fallback",
+			     &ans->oldrtb_dma_addr, ans->oldrtb_packet_len,
+			     ans->oldrtb_packet_seq, ans->oldrtb_packet_format);
+	len += sysfs_emit_at(buf, len,
+			     "last_send name=%s msg=%016llx a2i_ctl=%08x packet_len=0x%x\n",
+			     ans->oldrtb_addr_last[0] ? ans->oldrtb_addr_last : "none",
+			     ans->oldrtb_addr_last_msg,
+			     ans->oldrtb_addr_last_a2i_ctl,
+			     ans->oldrtb_addr_last_len);
+	len += sysfs_emit_at(buf, len,
+			     "usage=echo '<variant> <candidate>' > oldrtbuddy_packet_addr_send\n");
+	len += sysfs_emit_at(buf, len,
+			     "variants=old-small old-0x40\n");
+	for (i = 0; i < ARRAY_SIZE(oldrtb_addr_candidates); i++)
+		len += sysfs_emit_at(buf, len, "candidate=%s desc=%s\n",
+				     oldrtb_addr_candidates[i].name,
+				     oldrtb_addr_candidates[i].desc);
+	len += sysfs_emit_at(buf, len,
+			     "guard=send is refused unless the observed old RTBuddy management loop is stable and AKF A2I is not full\n");
+
+	return len;
+}
+static DEVICE_ATTR_RO(oldrtbuddy_packet_addr_plan);
