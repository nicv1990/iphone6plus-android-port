+static int apple_t7000_ans_probe(struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	struct apple_t7000_ans *ans;
+	struct resource *res;
+	resource_size_t size;
+	int irq;
+	int ret;
+	int i;
+
+	res = platform_get_resource(pdev, IORESOURCE_MEM, 0);
+	if (!res)
+		return dev_err_probe(dev, -ENODEV, "missing ANS MMIO resource\n");
+
+	ans = devm_kzalloc(dev, sizeof(*ans), GFP_KERNEL);
+	if (!ans)
+		return -ENOMEM;
+
+	ans->dev = dev;
+	ans->regs = devm_platform_ioremap_resource(pdev, 0);
+	if (IS_ERR(ans->regs))
+		return dev_err_probe(dev, PTR_ERR(ans->regs), "failed to map ANS MMIO\n");
+
+	size = resource_size(res);
+	ans->size = size;
+	dev_set_drvdata(dev, ans);
+
+	dev_notice(dev, "T7000 ANS diag: mmio=%pa..%pa size=%pa\n",
+		   &res->start, &res->end, &size);
+
+	ret = dma_set_mask_and_coherent(dev, DMA_BIT_MASK(32));
+	if (ret)
+		dev_warn(dev, "T7000 ANS diag: 32-bit coherent DMA mask failed: %d\n",
+			 ret);
+	else
+		dev_notice(dev, "T7000 ANS diag: using 32-bit coherent DMA mask\n");
+
+	for (i = 0; i < 4; i++) {
+		irq = platform_get_irq_optional(pdev, i);
+		if (irq < 0)
+			dev_notice(dev, "T7000 ANS diag: irq%d unavailable (%d)\n", i, irq);
+		else
+			dev_notice(dev, "T7000 ANS diag: irq%d=%d\n", i, irq);
+	}
+
+	pm_runtime_enable(dev);
+	ret = pm_runtime_resume_and_get(dev);
+	ans->pm_ret = ret;
+	if (ret)
+		dev_warn(dev, "T7000 ANS diag: power-domain resume failed: %d\n", ret);
+	else
+		dev_notice(dev, "T7000 ANS diag: power-domain resume succeeded\n");
+
+	ret = device_create_file(dev, &dev_attr_regs);
+	if (ret)
+		return dev_err_probe(dev, ret, "failed to create regs sysfs file\n");
+
+	ret = device_create_file(dev, &dev_attr_state);
+	if (ret) {
+		device_remove_file(dev, &dev_attr_regs);
+		return dev_err_probe(dev, ret, "failed to create state sysfs file\n");
+	}
+
+	ret = device_create_file(dev, &dev_attr_mbox);
+	if (ret) {
+		device_remove_file(dev, &dev_attr_state);
+		device_remove_file(dev, &dev_attr_regs);
+		return dev_err_probe(dev, ret, "failed to create mbox sysfs file\n");
+	}
+
+	ret = device_create_file(dev, &dev_attr_akf_mbox);
+	if (ret) {
+		device_remove_file(dev, &dev_attr_mbox);
+		device_remove_file(dev, &dev_attr_state);
+		device_remove_file(dev, &dev_attr_regs);
+		return dev_err_probe(dev, ret, "failed to create akf_mbox sysfs file\n");
+	}
+
+	ret = device_create_file(dev, &dev_attr_rxpoll);
+	if (ret) {
+		device_remove_file(dev, &dev_attr_akf_mbox);
+		device_remove_file(dev, &dev_attr_mbox);
+		device_remove_file(dev, &dev_attr_state);
+		device_remove_file(dev, &dev_attr_regs);
+		return dev_err_probe(dev, ret, "failed to create rxpoll sysfs file\n");
+	}
+
+	ret = device_create_file(dev, &dev_attr_akf_rxpoll);
+	if (ret) {
+		device_remove_file(dev, &dev_attr_rxpoll);
+		device_remove_file(dev, &dev_attr_akf_mbox);
+		device_remove_file(dev, &dev_attr_mbox);
+		device_remove_file(dev, &dev_attr_state);
+		device_remove_file(dev, &dev_attr_regs);
+		return dev_err_probe(dev, ret, "failed to create akf_rxpoll sysfs file\n");
+	}
+
+	ret = device_create_file(dev, &dev_attr_akf_decode);
+	if (ret) {
+		device_remove_file(dev, &dev_attr_akf_rxpoll);
+		device_remove_file(dev, &dev_attr_rxpoll);
+		device_remove_file(dev, &dev_attr_akf_mbox);
+		device_remove_file(dev, &dev_attr_mbox);
+		device_remove_file(dev, &dev_attr_state);
+		device_remove_file(dev, &dev_attr_regs);
+		return dev_err_probe(dev, ret, "failed to create akf_decode sysfs file\n");
