+static ssize_t send_raw_store(struct device *dev, struct device_attribute *attr,
+			      const char *buf, size_t count)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	u64 msg0;
+	u64 msg1;
+	u32 a2i_ctl;
+	int ret;
+
+	if (!ans || !ans->regs)
+		return -ENODEV;
+
+	ret = sscanf(buf, "%llx %llx", &msg0, &msg1);
+	if (ret != 2)
+		return -EINVAL;
+
+	a2i_ctl = readl(ans->regs + ASC_A2I_CONTROL);
+	if (a2i_ctl & ASC_CONTROL_FULL)
+		return -EBUSY;
