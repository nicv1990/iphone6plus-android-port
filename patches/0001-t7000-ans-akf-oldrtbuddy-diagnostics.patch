+static ssize_t oldrtbuddy_ordered_reply_store(struct device *dev,
+					      struct device_attribute *attr,
+					      const char *buf, size_t count)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	struct t7000_oldrtb_state st;
+	enum t7000_oldrtb_phase phase;
+	char phase_token[32];
+	u64 expected;
+	u64 reply;
+	u64 cur_msg;
+	u32 a2i_ctl;
+	int i;
+	int ret;
+
+	if (!ans || !ans->regs)
+		return -ENODEV;
+
+	ret = sscanf(buf, "%31s %llx", phase_token, &reply);
+	if (ret != 2)
+		return -EINVAL;
+
+	phase = oldrtb_phase_from_token(phase_token);
+	expected = oldrtb_phase_msg(phase);
+	if (!expected)
+		return -EINVAL;
+
+	ret = oldrtb_collect_state(ans, &st, 64);
+	if (ret)
+		return ret;
+
+	if (!oldrtb_state_is_stable(&st)) {
+		dev_notice(dev,
+			   "T7000 ANS AKF ordered reply skipped: unstable loop samples=%u unknown=%u seen_mask=%x loop_count=%u\n",
+			   st.samples, st.unknown, st.seen_mask, st.loop_count);
+		return -EAGAIN;
+	}
+
+	for (i = 0; i < 256; i++) {
+		cur_msg = akf_read_recv(ans);
+		if (oldrtb_classify_msg(cur_msg) == phase && cur_msg == expected)
+			break;
+		usleep_range(500, 1000);
+	}
+
+	if (i == 256) {
+		dev_notice(dev,
+			   "T7000 ANS AKF ordered reply skipped: phase not observed cur_msg=%016llx cur_phase=%s requested_phase=%s expected=%016llx\n",
+			   cur_msg, oldrtb_phase_name(oldrtb_classify_msg(cur_msg)),
+			   oldrtb_phase_name(phase), expected);
+		return -EAGAIN;
+	}
+
+	a2i_ctl = readl(ans->regs + AKF_A2I_CONTROL);
+	if (a2i_ctl & AKF_CONTROL_FULL)
+		return -EBUSY;
+
+	dev_notice(dev,
+		   "T7000 ANS AKF ordered reply: stable loop_count=%u wait_samples=%d phase=%s expected=%016llx reply=%016llx a2i_ctl=%08x\n",
+		   st.loop_count, i, oldrtb_phase_name(phase), expected,
+		   reply, a2i_ctl);
+	akf_write_send(ans, reply);
+
+	return count;
+}
+static DEVICE_ATTR_WO(oldrtbuddy_ordered_reply);
+
+struct t7000_oldrtb_txn_step {
+	enum t7000_oldrtb_phase phase;
+	u64 reply;
+	const char *name;
+};
+
+static int oldrtb_send_phase_reply(struct apple_t7000_ans *ans,
+				   enum t7000_oldrtb_phase phase, u64 reply,
+				   int *wait_samples)
+{
+	u64 expected = oldrtb_phase_msg(phase);
+	u64 cur_msg = 0;
+	u32 a2i_ctl;
+	int i;
+
+	if (!expected)
+		return -EINVAL;
+
+	for (i = 0; i < 256; i++) {
+		cur_msg = akf_read_recv(ans);
+		if (oldrtb_classify_msg(cur_msg) == phase && cur_msg == expected)
+			break;
+		usleep_range(500, 1000);
+	}
+
+	if (i == 256) {
+		dev_notice(ans->dev,
+			   "T7000 ANS AKF txn skipped: phase not observed cur_msg=%016llx cur_phase=%s requested_phase=%s expected=%016llx\n",
+			   cur_msg, oldrtb_phase_name(oldrtb_classify_msg(cur_msg)),
+			   oldrtb_phase_name(phase), expected);
+		return -EAGAIN;
+	}
+
+	a2i_ctl = readl(ans->regs + AKF_A2I_CONTROL);
+	if (a2i_ctl & AKF_CONTROL_FULL)
+		return -EBUSY;
+
+	akf_write_send(ans, reply);
+	if (wait_samples)
+		*wait_samples = i;
+
+	dev_notice(ans->dev,
+		   "T7000 ANS AKF txn step: wait_samples=%d phase=%s expected=%016llx reply=%016llx a2i_ctl=%08x\n",
+		   i, oldrtb_phase_name(phase), expected, reply, a2i_ctl);
+
+	return 0;
+}
+
+static int oldrtb_run_txn(struct apple_t7000_ans *ans,
+			  const struct t7000_oldrtb_txn_step *steps,
+			  int nr_steps)
+{
+	struct t7000_oldrtb_state st;
+	int wait_samples;
+	int ret;
+	int i;
+
+	ret = oldrtb_collect_state(ans, &st, 64);
+	if (ret)
+		return ret;
+
+	if (!oldrtb_state_is_stable(&st)) {
+		dev_notice(ans->dev,
+			   "T7000 ANS AKF txn skipped: unstable loop samples=%u unknown=%u seen_mask=%x loop_count=%u\n",
+			   st.samples, st.unknown, st.seen_mask, st.loop_count);
+		return -EAGAIN;
+	}
+
+	for (i = 0; i < nr_steps; i++) {
+		ret = oldrtb_send_phase_reply(ans, steps[i].phase,
+					      steps[i].reply, &wait_samples);
+		if (ret) {
+			dev_notice(ans->dev,
+				   "T7000 ANS AKF txn failed step=%d name=%s ret=%d\n",
+				   i, steps[i].name, ret);
+			return ret;
+		}
+		usleep_range(1000, 2000);
+	}
+
+	return 0;
+}
+
+static ssize_t oldrtbuddy_transaction_plan_show(struct device *dev,
+					       struct device_attribute *attr,
+					       char *buf)
+{
