+	len += sysfs_emit_at(buf, len,
+			     "plans: canonical4 oldecho4 mixed-power-first mixed-state-first\n");
+	len += sysfs_emit_at(buf, len,
+			     "canonical4: state12=0060000000000012 state04=0060000000000004 ap_power10=0060000000000010 iop_ack01=0060000000000001\n");
+	len += sysfs_emit_at(buf, len,
+			     "oldecho4: state12=0600000000000012 state04=0600000000000004 ap_power10=00b0000000000010 iop_ack01=0070000000000001\n");
+	len += sysfs_emit_at(buf, len,
+			     "mixed-power-first: ap_power10 canonical then iop_ack01 canonical then state12/state04 canonical\n");
+	len += sysfs_emit_at(buf, len,
+			     "mixed-state-first: state12/state04 canonical then ap_power10/iop_ack01 canonical\n");
+	len += sysfs_emit_at(buf, len,
+			     "guard=each step waits for its live phase and exact expected message before sending\n");
+
+	return len;
+}
+static DEVICE_ATTR_RO(oldrtbuddy_transaction_plan);
+
+static ssize_t oldrtbuddy_transaction_store(struct device *dev,
+					   struct device_attribute *attr,
+					   const char *buf, size_t count)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	char plan[32];
+	int ret;
+
+	static const struct t7000_oldrtb_txn_step canonical4[] = {
+		{ OLDRTB_PHASE_IOP_STATE_12, 0x0060000000000012ULL, "canonical-state12" },
+		{ OLDRTB_PHASE_IOP_STATE_04, 0x0060000000000004ULL, "canonical-state04" },
+		{ OLDRTB_PHASE_AP_POWER_10, 0x0060000000000010ULL, "canonical-ap-power10" },
+		{ OLDRTB_PHASE_IOP_ACK_01, 0x0060000000000001ULL, "canonical-iop-ack01" },
+	};
+	static const struct t7000_oldrtb_txn_step oldecho4[] = {
+		{ OLDRTB_PHASE_IOP_STATE_12, AKF_KNOWN_BOOT_0, "oldecho-state12" },
+		{ OLDRTB_PHASE_IOP_STATE_04, AKF_KNOWN_BOOT_1, "oldecho-state04" },
+		{ OLDRTB_PHASE_AP_POWER_10, AKF_KNOWN_BOOT_2, "oldecho-ap-power10" },
+		{ OLDRTB_PHASE_IOP_ACK_01, AKF_KNOWN_BOOT_3, "oldecho-iop-ack01" },
+	};
+	static const struct t7000_oldrtb_txn_step mixed_power_first[] = {
+		{ OLDRTB_PHASE_AP_POWER_10, 0x0060000000000010ULL, "canonical-ap-power10" },
+		{ OLDRTB_PHASE_IOP_ACK_01, 0x0060000000000001ULL, "canonical-iop-ack01" },
+		{ OLDRTB_PHASE_IOP_STATE_12, 0x0060000000000012ULL, "canonical-state12" },
+		{ OLDRTB_PHASE_IOP_STATE_04, 0x0060000000000004ULL, "canonical-state04" },
+	};
+	static const struct t7000_oldrtb_txn_step mixed_state_first[] = {
+		{ OLDRTB_PHASE_IOP_STATE_12, 0x0060000000000012ULL, "canonical-state12" },
+		{ OLDRTB_PHASE_IOP_STATE_04, 0x0060000000000004ULL, "canonical-state04" },
+		{ OLDRTB_PHASE_AP_POWER_10, 0x0060000000000010ULL, "canonical-ap-power10" },
+		{ OLDRTB_PHASE_IOP_ACK_01, 0x0060000000000001ULL, "canonical-iop-ack01" },
+	};
+
+	if (!ans || !ans->regs)
+		return -ENODEV;
+
+	ret = sscanf(buf, "%31s", plan);
+	if (ret != 1)
+		return -EINVAL;
+
+	if (!strcmp(plan, "canonical4"))
+		ret = oldrtb_run_txn(ans, canonical4, ARRAY_SIZE(canonical4));
+	else if (!strcmp(plan, "oldecho4"))
+		ret = oldrtb_run_txn(ans, oldecho4, ARRAY_SIZE(oldecho4));
+	else if (!strcmp(plan, "mixed-power-first"))
+		ret = oldrtb_run_txn(ans, mixed_power_first,
+				     ARRAY_SIZE(mixed_power_first));
+	else if (!strcmp(plan, "mixed-state-first"))
+		ret = oldrtb_run_txn(ans, mixed_state_first,
+				     ARRAY_SIZE(mixed_state_first));
+	else
+		return -EINVAL;
+
+	return ret ? ret : count;
+}
+static DEVICE_ATTR_WO(oldrtbuddy_transaction);
