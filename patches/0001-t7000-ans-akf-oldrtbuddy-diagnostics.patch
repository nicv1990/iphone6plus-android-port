+static ssize_t akf_send_if_current_store(struct device *dev, struct device_attribute *attr,
+					 const char *buf, size_t count)
+{
+	struct apple_t7000_ans *ans = dev_get_drvdata(dev);
+	u64 expect;
+	u64 reply;
+	u64 cur_msg;
+	u32 a2i_ctl;
+	int ret;
+
+	if (!ans || !ans->regs)
+		return -ENODEV;
+
+	ret = sscanf(buf, "%llx %llx", &expect, &reply);
+	if (ret != 2)
+		return -EINVAL;
+
+	cur_msg = akf_read_recv(ans);
+	if (cur_msg != expect) {
+		dev_notice(dev,
+			   "T7000 ANS AKF diag: guarded send skipped cur_msg=%016llx expected=%016llx\n",
+			   cur_msg, expect);
+		return -EAGAIN;
+	}
+
+	a2i_ctl = readl(ans->regs + AKF_A2I_CONTROL);
+	if (a2i_ctl & AKF_CONTROL_FULL)
+		return -EBUSY;
+
+	dev_notice(dev,
+		   "T7000 ANS AKF diag: guarded send cur_msg=%016llx reply=%016llx a2i_ctl=%08x\n",
+		   cur_msg, reply, a2i_ctl);
+	akf_write_send(ans, reply);
+
+	return count;
+}
+static DEVICE_ATTR_WO(akf_send_if_current);
