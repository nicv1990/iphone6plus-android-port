+	dev_notice(dev, "T7000 ANS diag: raw send msg0=%016llx msg1=%016llx a2i_ctl=%08x\n",
+		   msg0, msg1, a2i_ctl);
+
+	writeq(msg0, ans->regs + ASC_A2I_SEND0);
+	writeq(msg1, ans->regs + ASC_A2I_SEND1);
+
+	return count;
